# Django
DJANGO_ENV=production
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=your-domain.com,your-ip-address

# PostgreSQL
DB_NAME=baboom
DB_USER=baboom
DB_PASS=change-me-in-production
DB_HOST=db
DB_PORT=5432

# RabbitMQ
RABBITMQ_USER=baboom_broker
RABBITMQ_PASS=change-me-in-production

# Celery
CELERY_RESULT_BACKEND=rpc://

# Playwright (Optional)
PLAYWRIGHT_CDP_URL=http://host.docker.internal:9222
