# Django
DJANGO_ENV=production
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=your-domain.com,your-ip-address

# PostgreSQL
DB_NAME=baboom
DB_USER=baboom
DB_PASS=change-me-in-production
DB_HOST=db
DB_PORT=5432

# RabbitMQ
RABBITMQ_USER=baboom_broker
RABBITMQ_PASS=change-me-in-production

# Celery
CELERY_RESULT_BACKEND=rpc://

# Playwright (Optional)
PLAYWRIGHT_CDP_URL=http://host.docker.internal:9222

# LLM / AI Services (PydanticAI)
# Provider prefix is required for PydanticAI inference:
# 'google-gla' = Google Generative Language API (AI Studio)
# 'google-vertex' = Google Vertex AI
# 'openai' = OpenAI
LLM_MODEL=google-gla:gemini-3-flash-preview
LLM_API_KEY=your-api-key-here

# Logfire (Optional Observability)
LOGFIRE_TOKEN=your-logfire-token-here
