DJANGO_ENV=development
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,baboom.com.br,www.baboom.com.br
CATALOG_PRODUCTS_BROWSER_CACHE_SECONDS=300
CATALOG_PRODUCTS_EDGE_CACHE_SECONDS=21600

DB_NAME=baboom
DB_USER=baboom
DB_PASS=baboom
DB_HOST=db
DB_PORT=5432
POSTGRES_DATA_PATH=/mnt/database/postgres

RABBITMQ_USER=guest
RABBITMQ_PASS=guest
CELERY_RESULT_BACKEND=django-db

VITE_CATALOG_API_URL=/api/catalog/products/
VITE_ALERTS_API_URL=/api/alerts/subscribe/

AGENTS_API_URL=https://baboom.com.br/graphql/
AGENTS_API_KEY=replace-with-agents-api-key
IMAGE_REPORT_MODEL=google-gla:gemini-2.5-flash
STRUCTURED_EXTRACTION_MODEL=google-gla:gemini-3.1-flash-lite-preview
GEMINI_API_KEY=replace-with-gemini-api-key
AGENTS_HTTP_RETRIES=3
AGENTS_HTTP_RETRY_BACKOFF=0.6
AGENTS_IMAGE_FILTER_ENABLED=true
AGENTS_IMAGE_FILTER_STRIP_QUERY_FOR_DEDUPE=true
AGENTS_IMAGE_FILTER_MAX_IMAGES=0
AGENTS_IMAGE_FILTER_EXCLUDE_KEYWORDS=logo,icon,placeholder,sprite,swatch,avatar,badge,favicon,caveira

# Use infra/nginx/local.conf for local HTTP-only development.
NGINX_CONF=./infra/nginx/default.conf

# Production image tags. Override with immutable SHA tags when needed.
API_IMAGE=ghcr.io/rflemerson/baboom-api:latest
WEB_IMAGE=ghcr.io/rflemerson/baboom-web:latest
AGENTS_IMAGE=ghcr.io/rflemerson/baboom-agents:latest
