AGENTS_API_URL=http://localhost:8000/graphql/
AGENTS_API_KEY=change-me

# LLM provider keys (set only what you use)
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Image selection behavior
OCR_INCLUDE_ALL_TABLES=1
OCR_MAX_TABLE_CANDIDATES=24
OCR_MAX_IMAGES=12
OCR_MAX_NUTRITION_IMAGES=8
OCR_MAX_IMAGES_NO_NUTRITION=16
OCR_CV_TABLE_THRESHOLD=0.22
