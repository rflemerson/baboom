FROM node:22-alpine AS build

WORKDIR /app

ARG VITE_CATALOG_API_URL=/api/catalog/products/
ARG VITE_ALERTS_API_URL=/api/alerts/subscribe/
ARG VITE_SENTRY_DSN=
ARG VITE_SENTRY_TRACES_SAMPLE_RATE=0.0
ARG VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.0
ARG VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
ARG VITE_SENTRY_SEND_DEFAULT_PII=false
ARG VITE_SENTRY_ENABLE_LOGS=false

ENV VITE_CATALOG_API_URL=$VITE_CATALOG_API_URL
ENV VITE_ALERTS_API_URL=$VITE_ALERTS_API_URL
ENV VITE_SENTRY_DSN=$VITE_SENTRY_DSN
ENV VITE_SENTRY_TRACES_SAMPLE_RATE=$VITE_SENTRY_TRACES_SAMPLE_RATE
ENV VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=$VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE
ENV VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=$VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE
ENV VITE_SENTRY_SEND_DEFAULT_PII=$VITE_SENTRY_SEND_DEFAULT_PII
ENV VITE_SENTRY_ENABLE_LOGS=$VITE_SENTRY_ENABLE_LOGS

COPY apps/web/package*.json ./
RUN npm ci

COPY apps/web/ ./
RUN npm run build

FROM nginx:1.27-alpine

COPY apps/web/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
