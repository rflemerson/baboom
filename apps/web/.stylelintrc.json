{
  "extends": [
    "stylelint-config-standard",
    "stylelint-config-standard-scss",
    "stylelint-config-html/vue"
  ],
  "overrides": [
    {
      "files": [
        "**/*.scss"
      ],
      "customSyntax": "postcss-scss"
    }
  ],
  "rules": {
    "keyframes-name-pattern": "^(?:app|alert)(?:-[a-z0-9]+)+$",
    "selector-class-pattern": "^(?:(?:app|alert)(?:-[a-z0-9]+)*(?:__(?:[a-z0-9]+(?:-[a-z0-9]+)*))?(?:--(?:[a-z0-9]+(?:-[a-z0-9]+)*))?|is-[a-z0-9]+(?:-[a-z0-9]+)*)$"
  }
}
